# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude .tfvars files that might contain sensitive data
*.tfvars
*.tfvars.json

# Allow environment-specific configuration files
!environments/*/terraform.tfvars

# Ignore override files as they're usually environment-specific
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock files
.terraform.lock.hcl

# IDE files
.vscode/
.idea/

# macOS specific files
.DS_Store
.AppleDouble
.LSOverride

# Terraform plan output
plan.out
plan.tfplan
tfplan
tfplan*
tfplan-*
*-plan.out
*-plan.tfplan

# Backup files
*.backup
*.bak
*.orig

# Credentials and secrets - never commit these
.env
.env.*
*.pem
*.key
secrets.tf
secrets.auto.tfvars

# Lambda deployment packages (if built locally)
*.zip

# Editor swap files
*.swp
*.swo

# Windows
Thumbs.db

# Snyk Security Extension - AI Rules (auto-generated)
.github/instructions/snyk_rules.instructions.md
